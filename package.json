{
  "name": "handik-booking-app",
  "version": "2.1.8.3",
  "private": true,
  "description": "Tooling (lint/format/test) for the Handik Booking App WordPress plugin.",
  "scripts": {
    "lint:js": "eslint \"assets/**/*.js\"",
    "lint:js:fix": "eslint \"assets/**/*.js\" --fix",
    "format": "prettier --write \"assets/**/*.{js,css}\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@wordpress/eslint-plugin": "^21.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/js/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "assets/booking-validators.js"
    ]
  }
}
